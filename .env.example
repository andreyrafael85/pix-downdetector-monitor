# ============================================================================
# PIX DownDetector Monitor — Environment Variables
# ATENÇÃO: Nunca commite este arquivo com valores reais!
#          Copie para .env e preencha com suas credenciais.
# ============================================================================

# ----------------------------------------------------------------------------
# Bright Data — Scraping Browser
# Formato: brd-customer-<CUSTOMER_ID>:<ZONE_PASSWORD>
# Onde obter: https://brightdata.com → Scraping Browser → Zone Credentials
# ----------------------------------------------------------------------------
AUTH=brd-customer-XXXXXXXXXXXXXXXX-XXXX-XXXX-XXXX-XXXXXXXXXXXX:XXXXXXXXXXXXXXXXXXXXXXXX

# ----------------------------------------------------------------------------
# Dynatrace — Tenant URL
# Formato SaaS: https://XXXXXXXX.live.dynatrace.com
# Formato Managed: https://your-managed-server/e/ENVIRONMENT_ID
# ----------------------------------------------------------------------------
DT_URL=https://XXXXXXXX.live.dynatrace.com

# ----------------------------------------------------------------------------
# Dynatrace — API Token
# Permissão necessária: metrics.ingest
# Onde criar: Settings → Access Tokens → Generate new token
# Formato: dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
# ----------------------------------------------------------------------------
DT_API_TOKEN=dt0c01.XXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXXX
